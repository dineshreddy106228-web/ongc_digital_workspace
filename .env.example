# ──────────────────────────────────────────────
# ONGC Digital Workspace – Environment Variables
# Copy this file to .env and fill in real values.
# NEVER commit the real .env to version control.
# ──────────────────────────────────────────────

# Flask
FLASK_ENV=development
FLASK_APP=run.py
SECRET_KEY=change-me-to-a-long-random-string

# MySQL Database
DB_HOST=localhost
DB_PORT=3306
DB_NAME=ongc_workspace
DB_USER=ongc_app
DB_PASSWORD=change-me

# Bootstrap Admin (created once via seed command)
BOOTSTRAP_ADMIN_USERNAME=superadmin
BOOTSTRAP_ADMIN_EMAIL=admin@ongc.example.com
BOOTSTRAP_ADMIN_PASSWORD=ChangeMe@First1

# Application
APP_NAME=ONGC Digital Workspace
PILOT_OFFICE_CODE=CORP_CHEM
